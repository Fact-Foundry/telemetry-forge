@using FactFoundry.TelemetryForge.Server.Data.Entities

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined"
                          Placeholder="e.g. My Website, Desktop App" Required="true"
                          Immediate="true" />
            <MudSelect @bind-Value="_type" Label="Type" Variant="Variant.Outlined" Required="true">
                <MudSelectItem Value="SiteType.Web">Web</MudSelectItem>
                <MudSelectItem Value="SiteType.Desktop">Desktop</MudSelectItem>
                <MudSelectItem Value="SiteType.Mobile">Mobile</MudSelectItem>
            </MudSelect>
            @if (_type == SiteType.Web)
            {
                <MudTextField @bind-Value="_domain" Label="Domain" Variant="Variant.Outlined"
                              Placeholder="e.g. kevinoftech.com" Immediate="true"
                              HelperText="Used to filter self-referrals in analytics" />
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="string.IsNullOrWhiteSpace(_name)">
            Register
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _name = string.Empty;
    private SiteType _type = SiteType.Web;
    private string _domain = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var domain = _type == SiteType.Web && !string.IsNullOrWhiteSpace(_domain)
            ? _domain.Trim().ToLowerInvariant()
            : null;
        MudDialog.Close(DialogResult.Ok(new RegisterResult(_name, _type, domain)));
    }

    public record RegisterResult(string Name, SiteType Type, string? Domain);
}
