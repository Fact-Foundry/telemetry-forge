@page "/sites"
@using FactFoundry.TelemetryForge.Server.Data
@using FactFoundry.TelemetryForge.Server.Data.Entities
@using FactFoundry.TelemetryForge.Server.Services
@inject TelemetryForgeDbContext Db
@inject ApiKeyService ApiKeyService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Sites & Apps — TelemetryForge</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Sites &amp; Apps</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           Class="mb-4" OnClick="OpenRegisterDialog">
    Register Site or App
</MudButton>

@if (_generatedKey is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _generatedKey = null">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">
                Copy your API key now — it will not be shown again.
            </MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                <MudText Typo="Typo.body2" Style="font-family: monospace;">@_generatedKey</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                               OnClick="CopyKeyToClipboard" />
            </MudStack>
        </MudStack>
    </MudAlert>
}

@if (!_sites.Any())
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Dns" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.h6">No sites registered yet</MudText>
            <MudText Typo="Typo.body1" Color="Color.Default">
                Register your first site or application to get an API key and start receiving telemetry.
            </MudText>
        </MudStack>
    </MudPaper>
}
else
{
    <MudTable Items="_sites" Hover="true" Elevation="1" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Domain</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Registered</MudTh>
            <MudTh>Last Payload</MudTh>
            <MudTh Style="width: 48px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@(context.Domain ?? "—")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="GetTypeColor(context.Type)">
                    @context.Type
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context)">
                    @GetStatusText(context)
                </MudChip>
            </MudTd>
            <MudTd>@context.RegisteredAt.ToString("yyyy-MM-dd")</MudTd>
            <MudTd>@(context.LastPayloadAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</MudTd>
            <MudTd>
                <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight">
                    <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => EditDomain(context)">
                        Edit Domain
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Refresh" OnClick="() => RegenerateKey(context)">
                        Regenerate Key
                    </MudMenuItem>
                    <MudMenuItem Icon="@Icons.Material.Filled.Delete" IconColor="Color.Error"
                                 OnClick="() => DeleteSite(context)">
                        Delete
                    </MudMenuItem>
                </MudMenu>
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<Site> _sites = [];
    private string? _generatedKey;

    protected override void OnInitialized()
    {
        LoadSites();
    }

    private void LoadSites()
    {
        _sites = Db.Sites.OrderByDescending(s => s.RegisteredAt).ToList();
    }

    private async Task OpenRegisterDialog()
    {
        var parameters = new DialogParameters<RegisterSiteDialog>();
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RegisterSiteDialog>("Register Site or App", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is RegisterSiteDialog.RegisterResult data)
        {
            var (rawKey, hash) = ApiKeyService.GenerateKey();

            var site = new Site
            {
                Id = Guid.NewGuid().ToString(),
                Name = data.Name,
                Type = data.Type,
                Domain = data.Domain,
                ApiKeyHash = hash,
                RegisteredAt = DateTime.UtcNow
            };

            Db.Sites.Add(site);
            await Db.SaveChangesAsync();

            _generatedKey = rawKey;
            LoadSites();
        }
    }

    private async Task RegenerateKey(Site site)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Regenerate API Key",
            $"This will revoke the current key for \"{site.Name}\" and generate a new one. Any applications using the old key will stop working.",
            "Regenerate", cancelText: "Cancel");

        if (confirmed != true)
            return;

        var (rawKey, hash) = ApiKeyService.GenerateKey();
        site.ApiKeyHash = hash;
        await Db.SaveChangesAsync();

        _generatedKey = rawKey;
        Snackbar.Add($"API key regenerated for {site.Name}.", Severity.Success);
    }

    private async Task DeleteSite(Site site)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Site",
            $"Are you sure you want to delete \"{site.Name}\" and all associated data? This cannot be undone.",
            "Delete", cancelText: "Cancel");

        if (confirmed != true)
            return;

        Db.Sites.Remove(site);
        await Db.SaveChangesAsync();

        _generatedKey = null;
        LoadSites();
        Snackbar.Add($"{site.Name} deleted.", Severity.Info);
    }

    private async Task CopyKeyToClipboard()
    {
        if (_generatedKey is not null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _generatedKey);
            Snackbar.Add("API key copied to clipboard.", Severity.Success);
        }
    }

    private async Task EditDomain(Site site)
    {
        var parameters = new DialogParameters<Dialogs.EditDomainDialog>
        {
            { x => x.Domain, site.Domain ?? string.Empty }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<Dialogs.EditDomainDialog>("Edit Domain", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled && result.Data is string domain)
        {
            site.Domain = string.IsNullOrWhiteSpace(domain) ? null : domain.Trim().ToLowerInvariant();
            await Db.SaveChangesAsync();
            Snackbar.Add($"Domain updated for {site.Name}.", Severity.Success);
        }
    }

    private static Color GetTypeColor(SiteType type) => type switch
    {
        SiteType.Web => Color.Info,
        SiteType.Desktop => Color.Secondary,
        SiteType.Mobile => Color.Tertiary,
        _ => Color.Default
    };

    private static Color GetStatusColor(Site site)
    {
        if (site.LastPayloadAt is null) return Color.Default;
        if (site.LastPayloadAt > DateTime.UtcNow.AddHours(-24)) return Color.Success;
        return Color.Warning;
    }

    private static string GetStatusText(Site site)
    {
        if (site.LastPayloadAt is null) return "Never received";
        if (site.LastPayloadAt > DateTime.UtcNow.AddHours(-24)) return "Active";
        return $"Idle ({(DateTime.UtcNow - site.LastPayloadAt.Value).Days}d)";
    }
}
