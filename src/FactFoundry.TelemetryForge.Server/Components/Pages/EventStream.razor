@page "/events"

<PageTitle>Event Stream — TelemetryForge</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Event Stream</MudText>

<MudStack Row="true" Spacing="2" Class="mb-4">
    <MudSelect T="string" @bind-Value="_siteFilter" Label="Site" Variant="Variant.Outlined" Dense="true"
               Style="max-width: 250px;" Immediate="true">
        <MudSelectItem T="string" Value="@string.Empty">All Sites</MudSelectItem>
        @foreach (var site in _sites)
        {
            <MudSelectItem T="string" Value="@site.Id">@site.Name</MudSelectItem>
        }
    </MudSelect>
    <MudSelect T="string" @bind-Value="_typeFilter" Label="Type" Variant="Variant.Outlined" Dense="true"
               Style="max-width: 150px;" Immediate="true">
        <MudSelectItem T="string" Value="@string.Empty">All Types</MudSelectItem>
        <MudSelectItem T="string" Value="@("Web")">Web</MudSelectItem>
        <MudSelectItem T="string" Value="@("Desktop")">Desktop</MudSelectItem>
        <MudSelectItem T="string" Value="@("Mobile")">Mobile</MudSelectItem>
    </MudSelect>
    <MudSwitch T="bool" Value="_hideBots" ValueChanged="OnHideBotsChanged" Label="Hide Bots" Color="Color.Primary" />
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="ApplyFilters"
               StartIcon="@Icons.Material.Filled.FilterList">
        Filter
    </MudButton>
</MudStack>

@if (!_events.Any())
{
    <MudPaper Class="pa-6" Elevation="1">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.h6">No events yet</MudText>
            <MudText Typo="Typo.body1" Color="Color.Default">
                Events will appear here as telemetry is received from your registered sites and apps.
            </MudText>
        </MudStack>
    </MudPaper>
}
else
{
    <MudTable Items="_events" Dense="true" Hover="true" Elevation="1">
        <HeaderContent>
            <MudTh Style="width:40px"></MudTh>
            <MudTh>Site</MudTh>
            <MudTh>Source</MudTh>
            <MudTh>Event</MudTh>
            <MudTh>Visitor</MudTh>
            <MudTh>Page / Feature</MudTh>
            <MudTh>Session</MudTh>
            <MudTh>Country</MudTh>
            <MudTh>Time</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIconButton Icon="@(context.Expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               Size="Size.Small" OnClick="() => context.Expanded = !context.Expanded" />
            </MudTd>
            <MudTd>@context.SiteName</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                         Color="@GetTypeColor(context.SourceType)">@context.SourceType</MudChip>
            </MudTd>
            <MudTd>
                @if (context.SourceType == "Web")
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Color="@GetWebEventColor(context.WebEventType)">@context.WebEventType</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Color="Color.Default">session</MudChip>
                }
            </MudTd>
            <MudTd>
                @if (context.IsBot)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Error">Bot</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(context.IsFirstSeen ? Color.Success : Color.Default)">
                        @(context.IsFirstSeen ? "New" : "Returning")
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                @if (context.SourceType == "Web")
                {
                    @(context.EventName ?? context.Page ?? "—")
                }
                else
                {
                    @($"{context.FeatureCount} features")
                }
            </MudTd>
            <MudTd Style="font-family:monospace;font-size:0.8rem;">@(context.SessionHash is not null ? context.SessionHash[..Math.Min(8, context.SessionHash.Length)] : "—")</MudTd>
            <MudTd>@(context.Country ?? "—")</MudTd>
            <MudTd>@context.Timestamp.ToString("g")</MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (context.Expanded)
            {
                <MudTr>
                    <td colspan="9">
                        <MudPaper Class="pa-4 ma-2" Elevation="0" Outlined="true">
                            <MudGrid Spacing="2">
                                @if (context.SourceType == "Web")
                                {
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Session</MudText>
                                        <MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.75rem;">@(context.SessionHash ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Page</MudText>
                                        <MudText Typo="Typo.body2">@(context.Page ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Status Code</MudText>
                                        <MudText Typo="Typo.body2">@(context.StatusCode > 0 ? context.StatusCode.ToString() : "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Country</MudText>
                                        <MudText Typo="Typo.body2">@(context.Country ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Browser</MudText>
                                        <MudText Typo="Typo.body2">@(context.Browser ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">OS</MudText>
                                        <MudText Typo="Typo.body2">@(context.Os ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Device Type</MudText>
                                        <MudText Typo="Typo.body2">@(context.DeviceType ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Language</MudText>
                                        <MudText Typo="Typo.body2">@(context.Language ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Referrer</MudText>
                                        <MudText Typo="Typo.body2">@(context.Referrer ?? "—")</MudText>
                                    </MudItem>
                                    @if (context.WebEventType == "link_click" && context.TargetUrl is not null)
                                    {
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption">Target URL</MudText>
                                            <MudText Typo="Typo.body2">@context.TargetUrl</MudText>
                                        </MudItem>
                                    }
                                    @if (context.WebEventType == "custom" && context.EventName is not null)
                                    {
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption">Custom Event</MudText>
                                            <MudText Typo="Typo.body2">@context.EventName</MudText>
                                        </MudItem>
                                    }
                                }
                                else
                                {
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Session Start</MudText>
                                        <MudText Typo="Typo.body2">@context.Timestamp.ToString("G")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Session End</MudText>
                                        <MudText Typo="Typo.body2">@(context.SessionEnd?.ToString("G") ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Duration</MudText>
                                        <MudText Typo="Typo.body2">@FormatDuration(context.DurationMs)</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">App Version</MudText>
                                        <MudText Typo="Typo.body2">@(context.AppVersion ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">OS Version</MudText>
                                        <MudText Typo="Typo.body2">@(context.OsVersion ?? "—")</MudText>
                                    </MudItem>
                                    @if (context.SourceType == "Desktop")
                                    {
                                        <MudItem xs="12" sm="6" md="4">
                                            <MudText Typo="Typo.caption">Fingerprint</MudText>
                                            <MudText Typo="Typo.body2" Style="font-family:monospace;font-size:0.8rem;">@(context.FingerprintHash ?? "—")</MudText>
                                        </MudItem>
                                    }
                                    else
                                    {
                                        <MudItem xs="12" sm="6" md="4">
                                            <MudText Typo="Typo.caption">Device Hash Type</MudText>
                                            <MudText Typo="Typo.body2">@(context.DeviceHashType ?? "—")</MudText>
                                        </MudItem>
                                    }
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Features Used</MudText>
                                        <MudText Typo="Typo.body2">@context.FeatureCount</MudText>
                                    </MudItem>
                                    <MudItem xs="12" sm="6" md="4">
                                        <MudText Typo="Typo.caption">Errors</MudText>
                                        <MudText Typo="Typo.body2">@context.ErrorCount</MudText>
                                    </MudItem>
                                    @if (context.FeaturePath.Count > 0)
                                    {
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption">Feature Path</MudText>
                                            <MudText Typo="Typo.body2">@string.Join(" → ", context.FeaturePath)</MudText>
                                        </MudItem>
                                    }
                                    @if (context.ErrorEvents.Count > 0)
                                    {
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.caption">Errors</MudText>
                                            @foreach (var err in context.ErrorEvents)
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Error">
                                                    @err.Feature — @err.Message (@err.Timestamp.ToString("G"))
                                                </MudText>
                                            }
                                        </MudItem>
                                    }
                                }
                            </MudGrid>
                        </MudPaper>
                    </td>
                </MudTr>
            }
        </ChildRowContent>
    </MudTable>
}
